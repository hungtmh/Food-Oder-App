<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Toolbar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/surface"
        android:elevation="2dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/text_primary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Đánh giá sản phẩm"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="end" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Top Rating Summary -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:orientation="horizontal"
                android:padding="16dp">

                <!-- Left Column (Average Rating & Stars) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="16dp"
                    android:gravity="center"
                    android:minWidth="100dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvAvgRating"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0.0"
                        android:textColor="@color/primary"
                        android:textSize="48sp"
                        android:textStyle="bold" />

                    <RatingBar
                        android:id="@+id/rbAvgRating"
                        style="?android:attr/ratingBarStyleSmall"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:progressTint="@color/primary"
                        android:stepSize="0.1" />

                    <TextView
                        android:id="@+id/tvTotalReviews"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="0 Nhận xét"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp" />
                </LinearLayout>

                <View
                    android:layout_width="1dp"
                    android:layout_height="match_parent"
                    android:layout_marginEnd="16dp"
                    android:background="@color/divider" />

                <!-- Right Column (Progress bars) -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <!-- 5 Stars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="5" android:textSize="12sp" android:textColor="@color/text_secondary" />
                        <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" app:tint="@color/text_secondary" />
                        <ProgressBar android:id="@+id/pbStar5" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp" android:layout_marginHorizontal="8dp" android:progressDrawable="@drawable/bg_progress_bar" android:max="100" />
                        <TextView android:id="@+id/tvCount5" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="end" />
                    </LinearLayout>

                    <!-- 4 Stars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4" android:textSize="12sp" android:textColor="@color/text_secondary" />
                        <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" app:tint="@color/text_secondary" />
                        <ProgressBar android:id="@+id/pbStar4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp" android:layout_marginHorizontal="8dp" android:progressDrawable="@drawable/bg_progress_bar" android:max="100" />
                        <TextView android:id="@+id/tvCount4" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="end" />
                    </LinearLayout>

                    <!-- 3 Stars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3" android:textSize="12sp" android:textColor="@color/text_secondary" />
                        <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" app:tint="@color/text_secondary" />
                        <ProgressBar android:id="@+id/pbStar3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp" android:layout_marginHorizontal="8dp" android:progressDrawable="@drawable/bg_progress_bar" android:max="100" />
                        <TextView android:id="@+id/tvCount3" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="end" />
                    </LinearLayout>

                    <!-- 2 Stars -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2" android:textSize="12sp" android:textColor="@color/text_secondary" />
                        <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" app:tint="@color/text_secondary" />
                        <ProgressBar android:id="@+id/pbStar2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp" android:layout_marginHorizontal="8dp" android:progressDrawable="@drawable/bg_progress_bar" android:max="100" />
                        <TextView android:id="@+id/tvCount2" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="end" />
                    </LinearLayout>

                    <!-- 1 Star -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textSize="12sp" android:textColor="@color/text_secondary" />
                        <ImageView android:layout_width="12dp" android:layout_height="12dp" android:layout_marginStart="4dp" android:src="@drawable/ic_star" app:tint="@color/text_secondary" />
                        <ProgressBar android:id="@+id/pbStar1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="0dp" android:layout_weight="1" android:layout_height="8dp" android:layout_marginHorizontal="8dp" android:progressDrawable="@drawable/bg_progress_bar" android:max="100" />
                        <TextView android:id="@+id/tvCount1" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="12sp" android:textColor="@color/text_secondary" android:gravity="end" />
                    </LinearLayout>

                </LinearLayout>
            </LinearLayout>

            <!-- Write Review Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:padding="16dp">

                <TextView
                    android:id="@+id/btnWriteReview"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_button_outline"
                    android:gravity="center"
                    android:text="VIẾT ĐÁNH GIÁ"
                    android:textColor="@color/primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="8dp"
                android:background="@color/background" />

            <!-- Sort / Filter Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@color/surface"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvTotalReviewsLabel"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:text="0 Nhận xét"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/divider" />

                <TextView
                    android:id="@+id/tvFilterStar"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="?android:attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:text="Lọc theo sao ↓"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider" />

            <!-- No reviews hint -->
            <TextView
                android:id="@+id/tvNoReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="32dp"
                android:gravity="center"
                android:text="Chưa có đánh giá nào"
                android:textColor="@color/text_hint"
                android:textSize="14sp"
                android:visibility="gone" />

            <!-- Reviews list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:nestedScrollingEnabled="false" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
