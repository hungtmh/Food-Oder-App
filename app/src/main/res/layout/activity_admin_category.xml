<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerAdminCategory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý hệ thống"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Danh mục"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/categorySearchBar"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        app:layout_constraintTop_toBottomOf="@id/headerAdminCategory">

        <EditText
            android:id="@+id/edtCategorySearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Tìm tên danh mục..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/btnCategorySearch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Tìm" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/filterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="3dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/categorySearchBar">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1">

            <Spinner
                android:id="@+id/spFilterStatus"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:paddingEnd="22dp"
                android:spinnerMode="dropdown" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_down" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1">

            <Spinner
                android:id="@+id/spSortMode"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_search_bar"
                android:paddingEnd="22dp"
                android:spinnerMode="dropdown" />

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="8dp"
                android:clickable="false"
                android:focusable="false"
                android:importantForAccessibility="no"
                android:src="@drawable/ic_chevron_down" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutBulkActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="4dp"
        android:background="@drawable/bg_search_bar"
        android:orientation="vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/filterScroll">

        <TextView
            android:id="@+id/tvBulkSelectionCount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:text="Chưa chọn danh mục (tick ô vuông để chọn)"
            android:textColor="@color/text_primary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnSelectAllCategories"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="Chọn hết"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBulkToggleActive"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="Ẩn/Hiện"
                android:textAllCaps="false"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btnBulkSoftDelete"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:minWidth="0dp"
                android:paddingHorizontal="10dp"
                android:text="Xóa"
                android:textAllCaps="false"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Category List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminCategories"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:paddingHorizontal="10dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutBulkActions"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/layoutCategoryEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/layoutBulkActions"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvCategoryEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Không có danh mục nào"
            android:textColor="@color/text_hint"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnAddCategoryNow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Thêm ngay"
            android:textAllCaps="false" />
    </LinearLayout>

    <!-- FAB Add -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Thêm"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Nav -->
    <include
        android:id="@+id/adminBottomNav"
        layout="@layout/view_admin_bottom_nav_custom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
