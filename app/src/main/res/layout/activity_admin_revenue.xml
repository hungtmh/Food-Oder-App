                        android:background="#EEEEEE"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="0.8"
                            android:layout_height="wrap_content"
                            android:text="Ngày"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:padding="8dp"/>
                            
                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>
                            
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1.2"
                            android:layout_height="wrap_content"
                            android:text="Tên khách"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:padding="8dp"/>
                            
                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>
                            
                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="0.8"
                            android:layout_height="wrap_content"
                            android:text="Số đơn"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:padding="8dp"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="0.5"
                            android:layout_height="wrap_content"
                            android:text="Hạng"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:padding="8dp"/>
                    </TableRow>
                </TableLayout>

                <TextView
                    android:id="@+id/tvNoCustomerData"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Đang tải dữ liệu..."
                    android:textColor="@color/text_hint"
                    android:textSize="13sp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="12dp"
                    android:background="@color/divider" />

                <!-- === Top 10 món bán chạy === -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Top 10 món bán chạy"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TableLayout
                    android:id="@+id/tableTopFoods"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">

                    <TableRow
                        android:background="#EEEEEE"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="0.4"
                            android:layout_height="wrap_content"
                            android:text="Hạng"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:padding="8dp"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1.2"
                            android:layout_height="wrap_content"
                            android:text="Tên món"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:padding="8dp"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="0.6"
                            android:layout_height="wrap_content"
                            android:text="Số lượng"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:padding="8dp"/>

                        <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#CCCCCC"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="0.8"
                            android:layout_height="wrap_content"
                            android:text="Doanh thu"
                            android:textStyle="bold"
                            android:textSize="11sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:padding="8dp"/>
                    </TableRow>
                </TableLayout>

                <TextView
                    android:id="@+id/tvNoTopFoods"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Chưa có dữ liệu"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
    </ScrollView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.navigation.NavigationView
        android:id="@+id/adminNavigationView"
