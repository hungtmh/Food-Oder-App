<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_admin_card"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="5dp"
    android:padding="12dp">

    <!-- Row 1: Order code + Status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvOrderCode"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ORD-XXXX"
            android:textColor="@color/primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvOrderStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chờ xác nhận"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:background="@drawable/bg_status_pending"
            android:paddingHorizontal="10dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="8dp"
        android:background="@color/divider" />

    <!-- Row 2: Food images preview (horizontally scrollable) -->
    <HorizontalScrollView
        android:id="@+id/scrollFoodImages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:id="@+id/layoutFoodImages"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical" />
    </HorizontalScrollView>

    <!-- Row 3: Food names summary -->
    <TextView
        android:id="@+id/tvFoodSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_primary"
        android:textSize="13sp"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginBottom="6dp" />

    <!-- Row 4: Customer + Date -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_person"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvOrderCustomer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tên khách"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_clock"
            android:layout_marginEnd="4dp" />

        <TextView
            android:id="@+id/tvOrderDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_hint"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Row 5: Total amount -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tổng tiền:"
            android:textColor="@color/text_secondary"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/tvOrderTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 VNĐ"
            android:textColor="@color/primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Row 6: Quick action buttons -->
    <LinearLayout
        android:id="@+id/layoutQuickActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal"
        android:gravity="end"
        android:visibility="gone">

        <Button
            android:id="@+id/btnQuickConfirm"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_primary"
            android:text="✓ Xác nhận"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"
            android:minWidth="0dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnQuickServe"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_button_primary"
            android:text="🍽 Phục vụ"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"
            android:minWidth="0dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnQuickCancel"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_button_danger"
            android:text="✕ Hủy"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:paddingHorizontal="16dp"
            android:minWidth="0dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
