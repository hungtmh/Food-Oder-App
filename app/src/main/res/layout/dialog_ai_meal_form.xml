<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Gợi ý combo món ăn"
        android:textColor="@color/text_primary"
        android:textSize="20sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="AI sẽ phân tích và đề xuất combo phù hợp nhất"
        android:textColor="@color/text_hint"
        android:textSize="13sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Mức ngân sách (VNĐ)"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etBudget"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_edit_text"
        android:hint="Ví dụ: 200000"
        android:inputType="number"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Số người ăn"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etPeopleCount"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_edit_text"
        android:hint="Ví dụ: 2"
        android:inputType="number"
        android:paddingHorizontal="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Khẩu vị"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <Spinner
        android:id="@+id/spTaste"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_edit_text"
        android:paddingHorizontal="12dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Mô tả thêm (tùy chọn)"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etDescription"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/bg_edit_text"
        android:gravity="top"
        android:hint="Ví dụ: Mình thích đồ cay, không ăn hải sản..."
        android:inputType="textMultiLine"
        android:padding="12dp"
        android:textColor="@color/text_primary"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="16dp"
        android:backgroundTint="@color/primary"
        android:text="Phân tích và gợi ý"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold" />

</LinearLayout>
