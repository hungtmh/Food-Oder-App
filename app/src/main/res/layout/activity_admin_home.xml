<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerAdmin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quản lý món ăn"
                android:textColor="@color/white"
                android:textSize="10sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đồ ăn"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageView
            android:id="@+id/btnAIInsights"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_ai"
            android:contentDescription="AI Insights"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <!-- Search Bar -->
    <LinearLayout
        android:id="@+id/adminSearchBar"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:layout_margin="12dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/headerAdmin">

        <EditText
            android:id="@+id/edtAdminSearch"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="@null"
            android:hint="Tên..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <ImageView
            android:id="@+id/btnAdminSearch"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_search"
            android:contentDescription="Tìm" />
    </LinearLayout>

    <!-- Filter bar -->
    <HorizontalScrollView
        android:id="@+id/foodFilterScroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/adminSearchBar">

        <LinearLayout
            android:id="@+id/foodFilterBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <Button
                android:id="@+id/btnFilterAll"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_category_selected"
                android:text="Tất cả"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingHorizontal="12dp" />

            <Button
                android:id="@+id/btnFilterAvailable"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_category_normal"
                android:text="Còn bán"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingHorizontal="12dp" />

            <Button
                android:id="@+id/btnFilterUnavailable"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_category_normal"
                android:text="Hết hàng"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingHorizontal="12dp" />

            <Button
                android:id="@+id/btnFilterPopular"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_category_normal"
                android:text="Phổ biến"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingHorizontal="12dp" />

            <Button
                android:id="@+id/btnFilterDiscount"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:layout_marginHorizontal="4dp"
                android:background="@drawable/bg_category_normal"
                android:text="Khuyến mãi"
                android:textColor="@color/text_primary"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:paddingHorizontal="12dp" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Food List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAdminFoods"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/foodFilterScroll"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav" />

    <!-- Empty State -->
    <TextView
        android:id="@+id/tvAdminEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Không có món ăn nào"
        android:textColor="@color/text_hint"
        android:textSize="16sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/foodFilterScroll"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- FAB Add -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddFood"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add"
        android:contentDescription="Thêm"
        app:backgroundTint="@color/primary"
        app:tint="@color/white"
        app:layout_constraintBottom_toTopOf="@id/adminBottomNav"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Bottom Nav (Custom 6 tabs) -->
    <include
        android:id="@+id/adminBottomNav"
        layout="@layout/view_admin_bottom_nav_custom"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
</androidx.constraintlayout.widget.ConstraintLayout>
